// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "show_edit_predictions": false,
  "edit_predictions": {
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    },
    "enabled_in_text_threads": false
  },

  "agent": {
    "use_modifier_to_send": true,
    "always_allow_tool_actions": true,
    "model_parameters": [],
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-opus-4-1"
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  "outline_panel": {
    "dock": "right"
  },
  "ui_font_size": 12,

  "buffer_font_family": "Berkeley Mono",
  "buffer_font_size": 10,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Xcode Default Dark"
  },

  "vim_mode": true,

  "terminal": {
    "max_scroll_history_lines": 100000
  },

  "languages": {
    "Make": {
      "hard_tabs": true
    },

    "Ruby": {
      "language_servers": [
        "ruby-lsp",
        "rubocop",
        "tailwindcss-language-server",
        "!solargraph"
      ]
    },

    "HTML": {
      "format_on_save": "off"
    },

    "CSS": {
      "format_on_save": "off"
    }
  },

  "lsp": {
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          // Zed does not currently support ruby-lsp's method of diagnostics
          // collection, so we disable that feature for now.
          "diagnostics": false
        }
      }
    },

    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "erb": "html",
          "ruby": "html"
        },
        "experimental": {
          "classRegex": ["\\bclass:\\s*['\"]([^'\"]*)['\"]"]
        }
      }
    }
  }
}

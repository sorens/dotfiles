// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "language_models": {
    "lmstudio": {
      "api_url": "http://localhost:1234/v1",
      "available_models": [
        {
          "name": "qwen/qwen3.6-35b-a3b",
          "display_name": "Qwen 3.6",
          "max_tokens": 32000,
          "supports_tool_calls": true,
          "supports_images": false,
        },
      ],
    },
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "soft_wrap": "editor_width",
  "show_wrap_guides": true,
  "show_edit_predictions": false,
  "edit_predictions": {
    "provider": "none",
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
  },

  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "favorite_models": [
      {
        "provider": "zed.dev",
        "model": "claude-opus-4-5-thinking",
      },
    ],
    "profiles": {
      "ask": {
        "name": "Ask",
        "tools": {
          "search_web": true,
          "terminal": true,
          "create_directory": true,
          "contents": true,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "thinking": true,
          "copy_path": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "commit_message_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-latest",
    },
    "default_profile": "write",
    "model_parameters": [],
    "default_model": {
      "enable_thinking": false,
      "provider": "lmstudio",
      "model": "qwen/qwen3.6-35b-a3b",
    },
    "dock": "right",
    "enabled": true,
    "use_modifier_to_send": true,
  },

  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "favorite_models": ["opus", "default"],
    },
  },

  "agent_ui_font_size": 24,

  "debugger": {
    "dock": "left",
  },

  "project_panel": {
    "show_diagnostics": "all",
    "dock": "left",
    "git_status": true,
  },

  "tabs": {
    "show_diagnostics": "all", // does not work, `off` only behavior
  },

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "lsp_pull_diagnostics": {
      "enabled": true,
      "debounce_ms": 50,
    },
    "inline": {
      "enabled": true, // yes, display diagnostic info to the right of a line
      "update_debounce_ms": 300,
      "padding": 4,
      "min_column": 80,
      "max_severity": "warning",
    },
  },

  "outline_panel": {
    "dock": "right",
  },

  "base_keymap": "VSCode",
  "buffer_font_family": "Ligalex Mono",
  "buffer_font_size": 20,
  "diagnostics_max_severity": null,
  "extend_comment_on_newline": false,
  "icon_theme": "Material Icon Theme",
  "ui_font_family": "BlexMono Nerd Font Propo",
  "ui_font_size": 24,
  "file_types": {
    "JSONC": ["*.csasm", "*.csprt"],
    "Shell Script": ["*.dotfiles/*.symlink"],
  },
  // "format_on_save": "off",

  "theme": {
    "mode": "system",
    "light": "XY-Zed",
    "dark": "XY-Zed",
  },

  "vim_mode": false,

  "terminal": {
    "dock": "bottom",
    "font_family": "Ligalex Mono",
    "font_size": 20,
    "max_scroll_history_lines": 100000,
  },

  "languages": {
    "Svelte": {
      "tab_size": 2,
    },
    "Make": {
      "hard_tabs": true,
    },

    "Ruby": {
      "language_servers": [
        "ruby-lsp",
        "rubocop",
        "tailwindcss-language-server",
        "!solargraph",
      ],
    },

    "HTML": {
      "format_on_save": "off",
    },

    "CSS": {
      "format_on_save": "off",
      "tab_size": 2,
      "language_servers": [
        "tailwindcss-intellisense-css",
        "!vscode-css-language-server",
      ],
    },

    "C": {
      "format_on_save": "off",
      "use_on_type_format": false,
      "prettier": {
        "allowed": false,
      },
    },

    "C++": {
      "format_on_save": "off",
      "use_on_type_format": false,
      "prettier": {
        "allowed": false,
      },
    },

    "CSharp": {
      "format_on_save": "off",
      "use_on_type_format": false,
      "prettier": {
        "allowed": false,
      },
    },

    "Go": {
      // "format_on_save": "on"
    },
  },

  "lsp": {
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          // Zed does not currently support ruby-lsp's method of diagnostics
          // collection, so we disable that feature for now.
          "diagnostics": false,
        },
      },
    },

    "omnisharp": {
      "settings": {
        "FormattingOptions": {
          "EnableEditorConfigSupport": true,
        },
      },
    },

    "svelte-language-server": {
      "initialization_options": {
        "configuration": {
          "svelte": {
            "plugin": {
              "css": {
                "diagnostics": {
                  // https://github.com/sveltejs/language-tools/tree/master/packages/language-server#svelteplugincssdiagnosticsenable
                  "enable": false,
                },
              },
            },
          },
        },
      },
    },

    "tailwindcss-language-server": {
      "settings": {
        "css": {
          "lint": {
            "unknownAtRules": "ignore",
          },
        },
        "includeLanguages": {
          "erb": "html",
          "ruby": "html",
          "svelte": "html",
        },
        "experimental": {
          "classRegex": ["\\bclass:\\s*['\"]([^'\"]*)['\"]"],
        },
      },
    },

    "vscode-css-language-server": {
      "settings": {
        "css": {
          "lint": {
            "unknownAtRules": "ignore",
          },
        },
      },
    },
  },

  "inlay_hints": {
    "enabled": false,
    "toggle_on_modifiers_press": {
      "alt": true,
      "control": true,
    },
  },
}
